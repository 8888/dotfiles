{
  "allowedWorkspaces": [
    "{{HOME}}/.agent-worktrees"
  ],
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  },
  "mcpServers": {
    "azure": {
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start",
        "--transport",
        "stdio"
      ],
      "trust": true
    },
    "chrome-devtools": {
      "command": "{{HOME}}/.claude/chrome-devtools-mcp.sh",
      "args": [],
      "trust": true
    },
    "github": {
      "httpUrl": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer $GITHUB_PERSONAL_ACCESS_TOKEN"
      },
      "trust": true
    }
  },
  "tools": {
    "shell": {
      "autoAccept": true,
      "enableInteractiveShell": true,
      "showColor": true
    },
    "confirmationMode": "auto"
  },
  "general": {
    "previewFeatures": true,
    "defaultApprovalMode": "auto_edit"
  },
  "experimental": {
    "enableAgents": true,
    "skills": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "footer": {
      "hideContextPercentage": false
    },
    "showMemoryUsage": true
  },
  "model": {
    "name": "gemini-3-flash-preview"
  }
}
