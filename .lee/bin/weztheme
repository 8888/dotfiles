#!/usr/bin/env zsh
# weztheme — switch WezTerm theme from the CLI
# Usage: weztheme [pixelgrim|squirrelsongdark|candywave|vortexbloom]
#        weztheme          (no args: show current + available)

STATE="$HOME/.wezterm_theme"
THEMES=(pixelgrim squirrelsongdark candywave vortexbloom)

if [[ $# -eq 0 ]]; then
  current=$([[ -f "$STATE" ]] && cat "$STATE" || echo 'candywave')
  echo "current:   $current"
  echo "available: [ ${(j: | :)THEMES} ]"
  exit 0
fi

SELECTED="${1:l}"

if [[ ! "${THEMES[(r)$SELECTED]}" == "$SELECTED" ]]; then
  echo "unknown theme: $SELECTED"
  echo "available: [ ${(j: | :)THEMES} ]"
  exit 1
fi

echo "$SELECTED" > "$STATE"
echo "switched to $SELECTED"
